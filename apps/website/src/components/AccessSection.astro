          <p class="text-xs font-black uppercase tracking-[0.26em] text-cyan-300">
            Llamada
          </p>

          <p class="mt-2 text-2xl font-black text-white">
            963 178 8473
          </p>
        </a>

        <a
          data-card
          href="mailto:contacto@fishermandistribucion.com.mx"
          class="fisherman-epic-info-card"
        >
          <p class="text-xs font-black uppercase tracking-[0.26em] text-cyan-300">
            Correo
          </p>

          <p class="mt-2 break-all text-xl font-black text-white md:text-2xl">
            contacto@fishermandistribucion.com.mx
