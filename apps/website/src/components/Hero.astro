  <div class="absolute inset-0 z-[2] bg-[linear-gradient(to_bottom,rgba(5,7,10,0.16),rgba(5,7,10,0.48),rgba(5,7,10,0.96))]"></div>
  <div class="absolute inset-0 z-[3] bg-[radial-gradient(circle_at_center,transparent_0%,rgba(5,7,10,0.2)_48%,rgba(5,7,10,0.78)_100%)]"></div>

  <div class="fisherman-container relative z-10 grid items-center gap-12 py-20 lg:grid-cols-[1.03fr_0.97fr]">
    <div>
