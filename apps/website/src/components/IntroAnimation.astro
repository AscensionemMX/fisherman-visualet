---
import { CHIAPAS_PLACES, CHIAPAS_ROUTES, projectChiapasToIntro } from "../data/chiapasMap";

const hub = projectChiapasToIntro(CHIAPAS_PLACES.comitan.coord);
const introRoutes = CHIAPAS_ROUTES.map((route) => ({
  ...route,
  d: route.coords
    .map((coord, index) => {
      const point = projectChiapasToIntro(coord);
      const command = index === 0 ? "M" : "L";

      return `${command} ${point.x.toFixed(1)} ${point.y.toFixed(1)}`;
    })
    .join(" "),
}));
const introNodes = [
  { ...hub, r: 10 },
  ...introRoutes.map((route) => {
    const point = projectChiapasToIntro(route.coords[route.coords.length - 1]);

    return { ...point, r: route.tone === "primary" ? 7 : 6 };
  }),
  ...introRoutes.map((route) => {
    const point = projectChiapasToIntro(route.coords[Math.floor(route.coords.length * 0.58)]);

    return { ...point, r: 4 };
  }),
];
