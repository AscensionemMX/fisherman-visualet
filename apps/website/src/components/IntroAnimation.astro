            <path class="fisherman-intro__terrain-ridge" d="M202 242 C308 190 406 210 504 278 C598 344 710 332 836 416" />
            <path class="fisherman-intro__terrain-ridge" d="M180 330 C284 300 356 328 444 384 C530 438 626 432 760 504" />
            <path class="fisherman-intro__terrain-ridge" d="M314 112 C396 148 456 210 516 258 C600 326 680 300 808 350" />
            <path class="fisherman-intro__terrain-valley" d="M270 454 C358 420 450 452 542 512 C610 554 694 538 804 532" />
            <path class="fisherman-intro__terrain-valley" d="M134 374 C228 368 306 396 388 456 C456 506 520 534 620 550" />
          </g>

          <use
            class="fisherman-intro__chiapas"
            href="#introChiapasShape"
            transform="translate(-2745 -2053) scale(2)"
          />
        </g>

        <g class="fisherman-intro__route-network" clip-path="url(#introChiapasClip)">
          {
            introRoutes.map((route) => (
              <path
                class:list={[
                  "fisherman-intro__route",
                  route.tone === "primary"
                    ? "fisherman-intro__route-main"
                    : "fisherman-intro__route-secondary",
                  route.tone === "promo" ? "fisherman-intro__route-promo" : "",
                ]}
                data-intro-route
                d={route.d}
              />
            ))
          }
        </g>

        <g class="fisherman-intro__pulse-layer" filter="url(#introGlow)">
          {
            introNodes.map((node) => (
              <circle data-intro-node cx={node.x.toFixed(1)} cy={node.y.toFixed(1)} r={node.r} />
            ))
          }
        </g>

        <g class="fisherman-intro__shipment" data-intro-shipment>
          <rect x="-18" y="-14" width="36" height="28" rx="6" />
          <path d="M-7 -14 V14 M7 -14 V14" />
        </g>

        <g class="fisherman-intro__shipment fisherman-intro__shipment-b" data-intro-shipment>
          <rect x="-15" y="-12" width="30" height="24" rx="5" />
          <path d="M0 -12 V12" />
        </g>

        <g class="fisherman-intro__hub" data-intro-hub>
          <circle cx={hub.x.toFixed(1)} cy={hub.y.toFixed(1)} r="58" />
          <circle cx={hub.x.toFixed(1)} cy={hub.y.toFixed(1)} r="31" />
          <path d={`M${hub.x.toFixed(1)} ${(hub.y - 35).toFixed(1)} V${(hub.y + 35).toFixed(1)} M${(hub.x - 35).toFixed(1)} ${hub.y.toFixed(1)} H${(hub.x + 35).toFixed(1)}`} />
        </g>
        </g>
      </svg>
    </div>

    <div class="fisherman-intro__copy" data-intro-copy>
      <p class="fisherman-intro__brand" data-intro-brand>
        Fisherman
      </p>

      <p class="fisherman-intro__kicker" data-intro-line>
        Desde Comitan, Chiapas
      </p>

      <h1 data-intro-line>
        Rutas que salen del centro y llegan con criterio.
      </h1>

      <p class="fisherman-intro__sub" data-intro-line>
        Distribucion farmaceutica con seguimiento, cobertura y atencion comercial.
      </p>
    </div>
  </div>

  <button class="fisherman-intro__skip" type="button" data-intro-skip>
    Entrar
  </button>
</section>

