---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Catálogo Fisherman | Productos y solicitud de compra"
  description="Explora productos Fisherman, revisa categorías y arma una solicitud de compra."
>
  <Navbar />

  <main class="min-h-screen bg-slate-100 pb-28 pt-24 text-slate-950 xl:pb-0">
    <div
      id="catalog-boot-screen"
      class="fixed inset-0 z-[120] hidden overflow-y-auto bg-[#05070A] px-4 py-6 text-white"
      aria-hidden="true"
    >
      <div class="absolute inset-0 overflow-hidden">
        <div class="catalog-boot-scanline"></div>
        <div class="absolute left-1/2 top-1/2 h-[34rem] w-[34rem] -translate-x-1/2 -translate-y-1/2 rounded-full border border-cyan-300/10"></div>
        <div class="absolute left-[8%] top-[12%] h-24 w-24 border border-cyan-300/15"></div>
        <div class="absolute bottom-[12%] right-[8%] h-32 w-32 border border-amber-300/15"></div>
      </div>

      <div class="relative z-10 mx-auto flex min-h-full max-w-5xl items-center">
        <div class="grid w-full gap-6 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-center">
          <section class="rounded-3xl border border-cyan-300/20 bg-white/[0.04] p-5 shadow-2xl shadow-cyan-950/30 backdrop-blur-xl md:p-8">
            <p class="text-xs font-black uppercase tracking-[0.34em] text-cyan-300">
              Visualet Sync
            </p>

            <h2 class="mt-4 max-w-3xl text-4xl font-black leading-tight md:text-6xl">
              Cargando catálogo completo.
            </h2>

            <p class="mt-5 max-w-2xl text-base leading-7 text-slate-300 md:text-lg">
              Visualet lee el sistema Fisherman antes de mostrar productos. Primero revisa
              Promociones, después categorías y al final trae el catálogo para
              que la solicitud salga con datos claros.
            </p>

            <div class="mt-8 grid gap-3 md:grid-cols-4">
              <div id="boot-checkpoint-promotions" class="catalog-boot-panel" data-state="idle">
                <span>01</span>
                <strong>Promociones</strong>
                <small>Prioridad comercial</small>
              </div>

              <div id="boot-checkpoint-categories" class="catalog-boot-panel" data-state="idle">
                <span>02</span>
                <strong>Categorías</strong>
                <small>Etiquetas Fisherman</small>
              </div>

              <div id="boot-checkpoint-coverage" class="catalog-boot-panel" data-state="idle">
                <span>03</span>
                <strong>Cobertura</strong>
                <small>Zona del cliente</small>
              </div>

              <div id="boot-checkpoint-products" class="catalog-boot-panel" data-state="idle">
                <span>04</span>
                <strong>Productos</strong>
                <small>Catálogo completo</small>
              </div>
            </div>

            <div class="mt-8">
              <div class="flex items-center justify-between gap-4 text-xs font-black uppercase tracking-[0.18em] text-slate-400">
                <p id="catalog-boot-progress-label">Iniciando</p>
                <p>Fisherman</p>
              </div>
              <div class="mt-3 h-3 overflow-hidden rounded-full border border-cyan-300/20 bg-white/[0.06]">
                <div
                  id="catalog-boot-progress-bar"
                  class="h-full w-[4%] rounded-full bg-gradient-to-r from-cyan-300 via-sky-300 to-amber-300 transition-all duration-500"
                ></div>
              </div>
            </div>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <button
                id="catalog-boot-wait"
                type="button"
                class="min-h-12 rounded-full bg-cyan-300 px-6 text-sm font-black text-slate-950 transition hover:bg-cyan-200"
              >
                Cargar completo
              </button>

              <button
                id="catalog-boot-skip"
                type="button"
                class="min-h-12 rounded-full border border-white/15 px-6 text-sm font-black text-slate-300 transition hover:bg-white/[0.08]"
              >
                Entrar mientras carga
              </button>
            </div>
          </section>

          <aside class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 backdrop-blur-xl">
            <p class="text-xs font-black uppercase tracking-[0.28em] text-slate-400">
              Estado
            </p>

            <div class="catalog-boot-loader mt-5" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>

            <div id="catalog-boot-game" class="catalog-boot-game mt-5">
              <div class="flex items-center justify-between gap-3">
                <p class="text-xs font-black uppercase tracking-[0.22em] text-cyan-200">
                  Mini ruta
                </p>
                <p id="catalog-boot-score" class="text-xs font-black text-amber-200">
                  0 capturas
                </p>
              </div>

              <div class="catalog-boot-game-board mt-3">
                <button
                  id="catalog-boot-target"
                  type="button"
                  class="catalog-boot-target"
                  aria-label="Capturar producto"
                >
                  +
                </button>
              </div>

              <p class="mt-3 text-xs leading-5 text-slate-400">
                Captura puntos mientras Visualet prepara el catálogo completo.
              </p>
            </div>

            <p id="catalog-boot-status" class="mt-6 text-sm font-black text-cyan-200">
              Conectando con Fisherman...
            </p>

            <p class="mt-3 text-sm leading-6 text-slate-400">
              Promociones tiene prioridad porque ahí Fisherman mueve producto
              sensible por fecha, inventario u oportunidad comercial.
            </p>
          </aside>
        </div>
      </div>
    </div>

    <section class="relative overflow-hidden px-4 py-6 md:py-10">
      <div class="absolute inset-0 opacity-70">
        <div class="absolute left-[-12%] top-[4%] h-96 w-96 rounded-full bg-cyan-200/50 blur-3xl"></div>
        <div class="absolute bottom-[-18%] right-[-10%] h-96 w-96 rounded-full bg-[#0F4C5C]/20 blur-3xl"></div>
      </div>

      <div class="fisherman-container relative z-10">
        <div class="grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
          <div>
            <p class="text-sm font-black uppercase tracking-[0.3em] text-[#0F4C5C]">
              Catálogo Fisherman
            </p>

            <h1 class="fisherman-heading mt-4 max-w-4xl text-4xl font-bold leading-tight md:text-6xl">
              Busca productos y arma tu solicitud.
            </h1>

            <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600 md:text-lg">
              Catálogo público para clientes y prospectos. Arma tu solicitud y Fisherman confirma precio, stock y seguimiento.
            </p>
          </div>

          <a
            href="https://wa.me/529631788473?text=Hola%20Fisherman%2C%20tengo%20dudas%20sobre%20un%20producto%20del%20cat%C3%A1logo."
            target="_blank"
            rel="noopener noreferrer"
            class="fisherman-button-secondary border-slate-300 text-slate-950 hover:bg-slate-950 hover:text-white"
          >
            Pedir ayuda
          </a>
        </div>

        <div class="mt-8 grid gap-6 xl:grid-cols-[minmax(0,1fr)_24rem]">
          <section class="rounded-3xl border border-slate-200 bg-white p-3 shadow-xl md:p-5">
            <div class="grid gap-3 lg:grid-cols-[minmax(0,1fr)_18rem]">
              <label class="block">
                <span class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">
                  Buscar producto
                </span>

                <input
                  id="catalog-search"
                  type="search"
                  placeholder="Nombre, código, marca o descripción..."
                  class="mt-2 w-full rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4 text-base font-semibold outline-none transition focus:border-[#0F4C5C] focus:bg-white"
                />
              </label>

              <label class="block">
                <span class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">
                  Categoría
                </span>

                <select
                  id="catalog-category"
                  class="mt-2 w-full rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4 text-base font-semibold outline-none transition focus:border-[#0F4C5C] focus:bg-white"
                >
                  <option value="todos">Todos</option>
                </select>
              </label>

            </div>

            <div id="catalog-category-buttons" class="mt-4 flex flex-wrap gap-2">
              <button data-category-button="todos" class="catalog-filter-active rounded-full px-4 py-2 text-sm font-black">
                Todos
              </button>
            </div>

            <section
              id="promotions-panel"
              class="mt-5 rounded-2xl border border-amber-200 bg-amber-50 p-4"
            >
              <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                  <p class="text-xs font-black uppercase tracking-[0.18em] text-amber-700">
                    Promociones
                  </p>
                  <h2 class="mt-1 text-xl font-black text-slate-950">
                    Productos para mover primero
                  </h2>
                  <p id="promotions-status" class="mt-1 text-sm font-bold text-amber-800">
                    Cargando promociones...
                  </p>
                </div>

                <button
                  id="view-promotions"
                  type="button"
                  class="min-h-11 rounded-full bg-amber-300 px-5 text-sm font-black text-slate-950 transition hover:bg-amber-200"
                >
                  Ver promociones
                </button>
              </div>

              <div id="promotions-list" class="mt-4 grid gap-2">
              </div>
            </section>

            <div class="mt-5 border-y border-slate-200 py-4">
              <div class="rounded-2xl bg-slate-50 p-3 md:p-4">
                <p class="text-[0.65rem] font-black uppercase tracking-[0.14em] text-slate-400 md:text-xs md:tracking-[0.2em]">
                  Resultados
                </p>
                <p id="catalog-count" class="mt-1 text-xl font-black text-slate-950 md:text-2xl">
                  0
                </p>
              </div>
            </div>

            <div class="mt-5 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
              <p id="catalog-source" class="text-xs font-bold uppercase tracking-[0.16em] text-slate-400">
                Cargando catálogo...
              </p>

              <p class="text-xs font-semibold text-slate-400">
                Precios, stock y seguimiento sujetos a confirmación Fisherman.
              </p>
            </div>

            <div
              id="catalog-grid"
              class="mt-4 grid gap-2.5 md:mt-5 md:gap-3"
            >
            </div>

            <div
              id="catalog-empty"
              class="mt-8 hidden rounded-2xl border border-slate-200 bg-slate-50 p-8 text-center"
            >
              <p class="text-xl font-black">
                No encontramos ese producto.
              </p>

              <p class="mt-2 text-slate-500">
                Escríbenos por WhatsApp y te ayudamos a buscarlo.
              </p>

              <a
                href="https://wa.me/529631788473?text=Hola%20Fisherman%2C%20no%20encontr%C3%A9%20un%20producto%20en%20el%20cat%C3%A1logo.%20%C2%BFMe%20pueden%20ayudar%3F"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-5 inline-flex rounded-full bg-[#0F4C5C] px-6 py-3 font-black text-white transition hover:bg-[#0B3D4A]"
              >
                Pedir ayuda
              </a>
            </div>

            <div class="mt-5 flex justify-center">
              <button
                id="catalog-load-more"
                type="button"
                class="hidden min-h-12 rounded-full bg-[#0F4C5C] px-6 text-sm font-black text-white transition hover:bg-[#0B3D4A]"
              >
                Ver más productos
              </button>
            </div>
          </section>

          <aside id="catalog-cart-panel" class="scroll-mt-24 xl:sticky xl:top-28 xl:self-start">
            <div class="rounded-3xl bg-[#05070A] p-5 text-white shadow-2xl">
              <p class="text-sm font-black uppercase tracking-[0.24em] text-cyan-300">
                Tu solicitud
              </p>

              <div class="mt-3 flex items-end justify-between gap-4">
                <div>
                  <h2 class="text-3xl font-black">
                    Pedido Fisherman
                  </h2>

                  <p id="cart-summary" class="mt-2 text-sm leading-6 text-slate-300">
                    0 productos agregados
                  </p>
                </div>

                <p id="cart-total" class="text-right text-xl font-black text-cyan-200">
                  $0.00
                </p>
              </div>

              <div class="mt-5 rounded-2xl border border-white/10 bg-white/[0.05] p-4">
                <div class="flex items-center justify-between gap-3">
                  <p id="cart-progress-label" class="text-sm font-black text-white">
                    Empieza tu solicitud
                  </p>

                  <p id="cart-progress-percent" class="text-sm font-black text-cyan-200">
                    0%
                  </p>
                </div>

                <div class="mt-3 h-2 overflow-hidden rounded-full bg-white/[0.08]">
                  <div
                    id="cart-progress-bar"
                    class="h-full w-0 rounded-full bg-cyan-300 transition-all duration-300"
                  >
                  </div>
                </div>

                <p id="cart-progress-hint" class="mt-3 text-xs leading-5 text-slate-400">
                  Agrega productos para preparar una solicitud clara.
                </p>
              </div>

              <div
                id="cart-list"
                class="mt-5 grid max-h-[24rem] gap-3 overflow-auto pr-1"
              >
              </div>

              <div
                id="cart-empty"
                class="mt-5 rounded-2xl border border-white/10 bg-white/[0.05] p-5 text-sm text-slate-400"
              >
                Agrega productos para armar tu solicitud.
              </div>

              <a
                id="send-order"
                href="https://wa.me/529631788473?text=Hola%20Fisherman%2C%20quiero%20hacer%20un%20pedido."
                target="_blank"
                rel="noopener noreferrer"
                class="mt-5 flex min-h-14 items-center justify-center rounded-full bg-cyan-300 px-6 text-center font-black text-slate-950 transition hover:bg-cyan-200"
              >
                Enviar solicitud
              </a>

              <button
                id="clear-cart"
                class="mt-3 w-full rounded-full border border-white/10 px-6 py-3 text-sm font-black text-slate-300 transition hover:bg-white/[0.08]"
              >
                Limpiar solicitud
              </button>

              <div
                id="recommendations-panel"
                class="mt-5 hidden rounded-2xl border border-white/10 bg-white/[0.05] p-4"
              >
                <p class="text-sm font-black text-white">
                  También puedes agregar
                </p>

                <div id="recommendations-list" class="mt-3 grid gap-2">
                </div>
              </div>

              <div class="mt-5 rounded-2xl border border-white/10 bg-white/[0.05] p-4">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-sm font-black text-white">
                      Entrega y cobertura
                    </p>
                    <p class="mt-1 text-xs leading-5 text-slate-400">
                      Escribe tu ubicación para revisar si hay atención próxima.
                    </p>
                  </div>

                  <span
                    id="route-status-pill"
                    class="rounded-full bg-cyan-300/10 px-3 py-1 text-xs font-black text-cyan-200"
                  >
                    Por confirmar
                  </span>
                </div>

                <div class="mt-4 rounded-2xl border border-white/10 bg-slate-950/60 p-3">
                  <label class="block">
                    <span class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                      Cliente
                    </span>
                    <input
                      id="customer-key"
                      type="text"
                      inputmode="text"
                      autocomplete="off"
                      placeholder="Clave, telefono o correo"
                      class="mt-2 w-full rounded-2xl border border-white/10 bg-slate-950 px-4 py-3 text-sm font-black text-white outline-none transition placeholder:text-slate-600 focus:border-cyan-300"
                    />
                  </label>

                  <div class="mt-3 grid grid-cols-[1fr_auto] gap-2">
                    <button
                      id="resolve-customer"
                      type="button"
                      class="min-h-11 rounded-full bg-cyan-300 px-4 text-sm font-black text-slate-950 transition hover:bg-cyan-200"
                    >
                      Detectar
                    </button>

                    <button
                      id="clear-customer"
                      type="button"
                      class="min-h-11 rounded-full border border-white/10 px-4 text-sm font-black text-slate-300 transition hover:bg-white/[0.08]"
                    >
                      Limpiar
                    </button>
                  </div>

                  <p id="customer-message" class="mt-3 text-xs leading-5 text-slate-400">
                    Si ya eres cliente, Visualet puede revisar cobertura desde tu cuenta.
                  </p>
                </div>

                <label class="mt-4 block">
                  <span class="text-xs font-black uppercase tracking-[0.18em] text-slate-500">
                    Ubicación de entrega
                  </span>
                  <input
                    id="customer-location"
                    type="text"
                    inputmode="text"
                    autocomplete="address-level2"
                    placeholder="Municipio, colonia o localidad"
                    class="mt-2 w-full rounded-2xl border border-white/10 bg-slate-950 px-4 py-3 text-sm font-black text-white outline-none transition placeholder:text-slate-600 focus:border-cyan-300"
                  />
                <button
                  id="resolve-coverage"
                  type="button"
                  class="mt-3 min-h-11 w-full rounded-full bg-cyan-300 px-4 text-sm font-black text-slate-950 transition hover:bg-cyan-200"
                >
                  Revisar cobertura
                </button>
                </label>

                <div class="mt-4 rounded-2xl bg-slate-950/70 p-4">
                  <p id="route-message-title" class="text-sm font-black text-cyan-200">
                    Cobertura por confirmar
                  </p>
                  <p id="route-message-summary" class="mt-2 text-sm font-bold leading-6 text-white">
                    Fisherman revisará tu zona antes de programar entrega.
                  </p>
                  <p id="route-message-detail" class="mt-2 text-xs leading-5 text-slate-400">
                    Puedes enviar tu solicitud; precio, stock, pago y entrega se confirman antes de cerrar.
                  </p>
                </div>
              </div>

              <div class="mt-5 rounded-2xl border border-white/10 bg-white/[0.05] p-4">
                <p class="text-sm font-black text-white">
                  Catálogo público
                </p>
                <p class="mt-2 text-xs leading-5 text-slate-400">
                  No muestra stock exacto. Fisherman confirma precio, stock y seguimiento antes de cerrar.
                </p>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <div
      id="product-image-modal"
      class="fixed inset-0 z-[80] hidden bg-slate-950/90 p-4 backdrop-blur-xl"
      aria-hidden="true"
    >
      <div class="mx-auto flex h-full max-w-5xl flex-col">
        <div class="flex items-center justify-between gap-4 py-3 text-white">
          <div class="min-w-0">
            <p class="text-xs font-black uppercase tracking-[0.24em] text-cyan-300">
              Foto del producto
            </p>
            <h2 id="product-image-title" class="truncate text-xl font-black">
              Producto Fisherman
            </h2>
          </div>

          <div class="flex items-center gap-2">
            <button
              id="product-image-zoom-out"
              type="button"
              class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/[0.06] text-lg font-black text-white transition hover:bg-white/[0.12]"
              aria-label="Alejar foto"
            >
              -
            </button>

            <button
              id="product-image-zoom-in"
              type="button"
              class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/[0.06] text-lg font-black text-white transition hover:bg-white/[0.12]"
              aria-label="Acercar foto"
            >
              +
            </button>

            <button
              id="product-image-close"
              type="button"
              class="flex h-11 min-w-11 items-center justify-center rounded-full bg-cyan-300 px-4 text-sm font-black text-slate-950 transition hover:bg-cyan-200"
            >
              Cerrar
            </button>
          </div>
        </div>

        <div class="flex min-h-0 flex-1 items-center justify-center overflow-hidden rounded-3xl border border-white/10 bg-white/[0.04] p-4">
          <img
            id="product-image-preview"
            src=""
            alt=""
            class="max-h-full max-w-full rounded-2xl object-contain transition-transform duration-200"
          />
        </div>
      </div>
    </div>

    <div
      id="catalog-toast"
      class="pointer-events-none fixed bottom-24 left-1/2 z-[90] hidden w-[min(92vw,28rem)] -translate-x-1/2 rounded-2xl border border-cyan-200/30 bg-slate-950/92 p-4 text-white shadow-2xl shadow-cyan-950/30 backdrop-blur-xl xl:bottom-5"
      aria-live="polite"
    >
      <p id="catalog-toast-title" class="text-sm font-black text-cyan-200">
        Producto agregado
      </p>

      <p id="catalog-toast-message" class="mt-1 text-sm leading-6 text-slate-300">
        Tu solicitud se actualizó.
      </p>
    </div>

    <div class="fixed inset-x-0 bottom-0 z-[70] border-t border-white/10 bg-slate-950/94 px-3 py-3 text-white shadow-2xl shadow-slate-950/40 backdrop-blur-xl xl:hidden">
      <div class="mx-auto grid max-w-2xl grid-cols-[1fr_auto_auto] items-center gap-2">
        <div class="min-w-0">
          <p id="mobile-cart-summary" class="truncate text-sm font-black">
            0 productos
          </p>

          <p id="mobile-cart-total" class="truncate text-xs font-bold text-cyan-200">
            $0.00
          </p>
        </div>

        <a
          href="#catalog-cart-panel"
          class="flex min-h-11 items-center justify-center rounded-full border border-white/10 px-4 text-sm font-black text-slate-200"
        >
          Ver
        </a>

        <a
          id="mobile-send-order"
          href="https://wa.me/529631788473?text=Hola%20Fisherman%2C%20quiero%20hacer%20un%20pedido."
          target="_blank"
          rel="noopener noreferrer"
          class="flex min-h-11 items-center justify-center rounded-full bg-cyan-300 px-4 text-sm font-black text-slate-950"
        >
          Enviar
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  import "../scripts/catalogPage";
</script>

<style is:inline>
  .catalog-filter-active {
    background: #0f4c5c;
    color: white;
    box-shadow: 0 10px 30px rgba(15, 76, 92, 0.22);
  }

  .catalog-filter-button {
    border-radius: 999px;
    background: #f1f5f9;
    padding: 0.5rem 1rem;
    color: #475569;
    font-size: 0.875rem;
    font-weight: 900;
    transition: background 180ms ease, color 180ms ease;
  }

  .catalog-filter-button:hover {
    background: #e2e8f0;
    color: #0f172a;
  }

  .catalog-boot-scanline {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(103, 232, 249, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(103, 232, 249, 0.06) 1px, transparent 1px);
    background-size: 100% 3rem, 3rem 100%;
    mask-image: radial-gradient(circle at center, black 0%, transparent 72%);
    animation: catalog-boot-grid 7s linear infinite;
  }

  .catalog-boot-panel {
