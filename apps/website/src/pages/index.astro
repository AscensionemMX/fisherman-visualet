---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import CorePromiseSection from "../components/CorePromiseSection.astro";
import StorySection from "../components/StorySection.astro";
import PrivateCatalogSection from "../components/PrivateCatalogSection.astro";
import AccessSection from "../components/AccessSection.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Fisherman Distribucion | Catalogo y atencion comercial"
  description="Distribucion farmaceutica con catalogo de productos, compra guiada y atencion comercial directa."
>
  <Navbar />

  <main>
    <Hero />
    <CorePromiseSection />
    <StorySection />
    <PrivateCatalogSection />
    <AccessSection />
  </main>

  <Footer />
</BaseLayout>
